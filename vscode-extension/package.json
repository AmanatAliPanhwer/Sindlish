{
    "name": "sindlish-lang",
    "displayName": "Sindlish",
    "description": "Language support for Sindlish (Singlish)",
    "version": "3.1.0",
    "publisher": "sindlish-dev",
    "icon": "logo.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/Sindlish/sindlish-lang"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:sindlish"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "sindlish",
                "aliases": [
                    "Sindlish",
                    "sd"
                ],
                "extensions": [
                    ".sd"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./logo-light.svg",
                    "dark": "./logo-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "sindlish",
                "scopeName": "source.sindlish",
                "path": "./syntaxes/sindlish.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -b",
        "watch": "tsc -b -w",
        "postinstall": "npm run compile"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    }
}
