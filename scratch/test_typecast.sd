likh("--- Typecasting Test ---")

# 1. String to Number
s = "123"
n = adad(s)
likh("adad('123') =", n)
likh("n + 1 =", n + 1)

# 2. Number to String
n2 = 456
s2 = lafz(n2)
likh("lafz(456) =", s2)
likh("s2 + '789' =", s2 + "789")

# 3. Float to Int
f = 3.14
i = adad(f)
likh("adad(3.14) =", i)

# 4. Int to Float
i2 = 10
f2 = dahai(i2)
likh("dahai(10) =", f2)

# 5. Boolean casts
likh("adad(sach) =", adad(sach))
likh("lafz(koorh) =", lafz(koorh))

# 6. Collection casts
l = [1, 2, 2, 3]
s_obj = majmuo(l)
likh("majmuo([1,2,2,3]) =", s_obj)
l2 = fehrist(s_obj)
likh("fehrist({1,2,3}) =", l2)

# 7. String to List
likh("fehrist('Sindh') =", fehrist("Sindh"))

likh("Tests complete!")
