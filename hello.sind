# He Duniay khe salam kando
agar 10 > 5:
    likh("Salam, Duniay.")

x = 2

agar x > 5:
    likh("Big")
warna:
  likh("Small")


x = 2 + 3 * 4
likh(x)

y = (2 + 3) * 4
likh(y)

z = 2 ^ 3
likh(z)

Amanat = 2 ^ 3 ^ 2
likh(Amanat)

x = 0

jistain x < 3:
    agar x < 2:
        likh("Inner")
    warna:
        likh("Else")

    x = x + 1